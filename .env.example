# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# OPENAI_API_KEY: Optional/Required for OpenAI Chat API calls.
# If not provided, the app will gracefully fall back to Gemini API for text chat.
OPENAI_API_KEY=MY_OPENAI_API_KEY

# OPENAI_API_BASE: Optional custom API base URL for OpenAI-compatible endpoints.
OPENAI_API_BASE=https://api.openai.com/v1/

# SUPABASE_URL: Optional/Required for cloud sync to Supabase.
SUPABASE_URL=MY_SUPABASE_URL

# SUPABASE_ANON_KEY: Optional/Required for cloud sync to Supabase.
SUPABASE_ANON_KEY=MY_SUPABASE_ANON_KEY


